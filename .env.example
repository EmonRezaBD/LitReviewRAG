# OpenAI API key (required for extraction + embeddings + synthesis)
OPENAI_API_KEY=my open ai key

# OpenRouter API key (optional - used for Llama baseline comparison)
OPENROUTER_API_KEY=my open router key

# ChromaDB local storage path (default: ./chroma_db)
CHROMA_PERSIST_DIR=./chroma_db

# Model names
EXTRACTION_MODEL=gpt-4o-mini
SYNTHESIS_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
BASELINE_MODEL=meta-llama/llama-3.1-70b-instruct